---
import App from "$layouts/App.astro";
import "$styles/global.less";
---

<App title="后台登录" author="admin">
	<main class="min-h-80vh grid place-items-center px-4">
		<form id="login-form" class="w-full max-w-90 flex flex-col gap-4 b b-solid b-weak rd-md p-5 bg-background">
			<h1 class="text-2xl font-bold">后台登录</h1>
			<label class="flex flex-col gap-1">
				<span>用户名</span>
				<input name="username" required class="b b-solid b-weak bg-background px-3 py-2 rd" />
			</label>
			<label class="flex flex-col gap-1">
				<span>密码</span>
				<input type="password" name="password" required class="b b-solid b-weak bg-background px-3 py-2 rd" />
			</label>
			<button type="submit" class="justify-center b b-solid b-primary px-3 py-2 rd hover:(bg-primary c-background)">登录</button>
			<p id="tip" class="text-sm c-secondary"></p>
		</form>
	</main>

	<script>
		document.getElementById("login-form")?.addEventListener("submit", async event => {
			event.preventDefault();
			const form = event.currentTarget;
			const tip = document.getElementById("tip");
			const formData = new FormData(form);
			const response = await fetch("/api/admin/login", { method: "POST", body: formData });
			if (response.ok) {
				location.href = "/admin";
				return;
			}
			const payload = await response.json().catch(() => ({}));
			if (tip) tip.textContent = payload.message ?? "登录失败";
		});
	</script>
</App>
