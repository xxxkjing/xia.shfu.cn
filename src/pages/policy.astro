---
import { render } from "astro:content";
import Base from "$layouts/Base.astro";
import { getEntry } from "astro:content";
import { getListSEO, getBreadcrumbSchema } from "$utils/seo";

const seoConfig = getListSEO(Astro.site!, Astro.url.pathname, "隐私政策", "xkjing 博客隐私政策，说明站点数据使用、统计与访问相关事项。");
const breadcrumbSchema = getBreadcrumbSchema(Astro.site!, [
	{ name: "首页", url: "/" },
	{ name: "隐私政策", url: Astro.url.pathname }
]);

const policy = await getEntry("information", "zh-cn/policy");
const { Content } = policy ? await render(policy) : ({} as any);
---

<Base title="隐私政策" seoConfig={seoConfig}>
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	<main>
		{
			policy && (
				<div class="markdown">
					<Content />
				</div>
			)
		}
	</main>
</Base>