---
interface RandomPostLink {
	href: string;
	title: string;
}

const { links = [], label = "文章" } = Astro.props as { links: RandomPostLink[]; label?: string };
---

<nav class="random-posts" data-random-posts={encodeURIComponent(JSON.stringify(links))}>
	<a class="random-post" data-random-link="0" href={links[0]?.href ?? "#"}>
		<span class="title">{links[0]?.title ?? "暂无可跳转文章"}</span>
		<span class="meta">#{label}</span>
	</a>
	<a class="random-post" data-random-link="1" href={links[1]?.href ?? "#"}>
		<span class="title">{links[1]?.title ?? "暂无可跳转文章"}</span>
		<span class="meta">#{label}</span>
	</a>
</nav>

<script>
	const pickRandomPosts = (items: { href: string; title: string }[]) => {
		if (!Array.isArray(items) || items.length === 0) return [];
		const list = [...items];
		for (let i = list.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[list[i], list[j]] = [list[j], list[i]];
		}
		return list.slice(0, Math.min(2, list.length));
	};

	for (const root of document.querySelectorAll("[data-random-posts]")) {
		const encoded = root.getAttribute("data-random-posts") ?? "";
		const links = JSON.parse(decodeURIComponent(encoded));
		const picked = pickRandomPosts(links);
		const anchors = root.querySelectorAll("[data-random-link]");

		anchors.forEach((anchor, index) => {
			const target = picked[index];
			const title = anchor.querySelector(".title");
			if (!target || !title) {
				if (title) title.textContent = "暂无可跳转文章";
				anchor.setAttribute("href", "#");
				anchor.setAttribute("aria-disabled", "true");
				return;
			}

			title.textContent = target.title;
			anchor.setAttribute("href", target.href);
			anchor.setAttribute("title", target.title);
			anchor.setAttribute("aria-label", `跳转到：${target.title}`);
			anchor.removeAttribute("aria-disabled");
		});
	}
</script>

<style lang="less">
	.random-posts {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;

		@media (min-width: 640px) {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.random-post {
			display: flex;
			flex-direction: column;
			align-items: flex-start;
			justify-content: center;
			gap: 0.1rem;

			padding: 0.5rem 0.7rem;
			min-height: 3rem;
			border: 1px solid var(--secondary-color);
			border-radius: 0.4rem;

			transition:
				color 0.12s ease-in-out,
				background-color 0.12s ease-in-out,
				border-color 0.12s ease-in-out;

			.title {
				font-size: 1.05rem;
				line-height: 1.3;
				word-break: break-word;
				font-weight: 600;
			}

			.meta {
				font-size: 0.78rem;
				color: var(--remark-color);
			}

			&:hover {
				background-color: var(--block-color);
				border-color: var(--primary-color);
			}

			&[aria-disabled="true"] {
				color: var(--weak-color);
				pointer-events: none;
			}
		}
	}
</style>
