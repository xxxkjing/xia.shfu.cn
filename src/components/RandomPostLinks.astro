---
interface RandomPostLink {
	href: string;
	title: string;
	tags?: string[];
}

const { links = [] } = Astro.props as { links: RandomPostLink[] };
---

<nav class="random-posts" data-random-posts={encodeURIComponent(JSON.stringify(links))}>
	{Array.from({ length: 4 }).map((_, index) => (
		<a class="random-post" data-random-link={String(index)} href={links[index]?.href ?? "#"}>
			<span class="title">{links[index]?.title ?? "暂无可跳转文章"}</span>
			<span class="meta">#{links[index]?.tags?.join(" #") ?? "推荐"}</span>
		</a>
	))}
</nav>

<script>
	const pickRandomPosts = (items: { href: string; title: string; tags?: string[] }[]) => {
		if (!Array.isArray(items) || items.length === 0) return [];
		const list = [...items];
		for (let i = list.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[list[i], list[j]] = [list[j], list[i]];
		}
		return list.slice(0, Math.min(4, list.length));
	};

	for (const root of document.querySelectorAll("[data-random-posts]")) {
		const encoded = root.getAttribute("data-random-posts") ?? "";
		const links = JSON.parse(decodeURIComponent(encoded));
		const picked = pickRandomPosts(links);
		const anchors = root.querySelectorAll("[data-random-link]");

		anchors.forEach((anchor, index) => {
			const target = picked[index];
			const title = anchor.querySelector(".title");
			const meta = anchor.querySelector(".meta");
			if (!target || !title || !meta) {
				if (title) title.textContent = "暂无可跳转文章";
				if (meta) meta.textContent = "#推荐";
				anchor.setAttribute("href", "#");
				anchor.setAttribute("aria-disabled", "true");
				return;
			}

			title.textContent = target.title;
			meta.textContent = target.tags?.length ? `#${target.tags.join(" #")}` : "#推荐";
			anchor.setAttribute("href", target.href);
			anchor.setAttribute("title", target.title);
			anchor.setAttribute("aria-label", `跳转到：${target.title}`);
			anchor.removeAttribute("aria-disabled");
		});
	}
</script>

<style lang="less">
	.random-posts {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.25rem 1rem;

		@media (min-width: 640px) {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	.random-post {
		display: flex;
		flex-direction: column;
		gap: 0.18rem;
		padding: 0.5rem 0.15rem 0.6rem;
		border-bottom: 1px dashed var(--weak-color);
		transition: color 0.12s ease;

		.title {
			font-size: 1.68rem;
			line-height: 1.35;
			font-weight: 600;
			word-break: break-word;
		}

		.meta {
			font-size: 0.84rem;
			color: var(--remark-color);
		}

		&:hover {
			color: var(--secondary-color);
		}

		&[aria-disabled="true"] {
			color: var(--weak-color);
			pointer-events: none;
		}
	}
</style>
