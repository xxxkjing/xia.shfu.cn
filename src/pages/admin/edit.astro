---
import { getEntry } from "astro:content";
import App from "$layouts/App.astro";
import Editor from "$components/admin/Editor.svelte";
import "$styles/global.less";
import "$styles/markdown.less";

export const prerender = false;

const type = Astro.url.searchParams.get("type") === "jotting" ? "jotting" : "note";
const id = Astro.url.searchParams.get("id")?.trim();

let initialData = {
	title: "",
	timestamp: new Date().toISOString().slice(0, 16),
	tags: [] as string[],
	description: "",
	sensitive: false,
	top: 0,
	draft: true,
	series: "",
	toc: false,
	body: "",
	slug: ""
};

if (id) {
	const entry = await getEntry(type, `zh-cn/${id}`);
	if (entry) {
		initialData = {
			title: entry.data.title,
			timestamp: entry.data.timestamp.toISOString().slice(0, 16),
			tags: entry.data.tags || [],
			description: entry.data.description || "",
			sensitive: entry.data.sensitive || false,
			top: entry.data.top || 0,
			draft: entry.data.draft || false,
			series: "series" in entry.data ? entry.data.series || "" : "",
			toc: "toc" in entry.data ? entry.data.toc || false : false,
			body: entry.body ?? "",
			slug: id
		};
	}
}
---

<App title="编辑文章" subtitle="Admin Editor" description="Admin editor" author="admin">
	<main class="mx-a w-[min(100%,1400px)] px-4 py-4 flex flex-col gap-4">
		<header class="flex items-center justify-between gap-4">
			<h1 class="text-xl font-bold">{id ? "编辑文章" : "新建文章"} · {type}</h1>
			<a href="/admin" class="b b-solid b-weak rd-1 px-3 py-1">返回管理页</a>
		</header>
		<Editor collectionType={type} {initialData} client:load />
	</main>
</App>
